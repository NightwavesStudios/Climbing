; Engine configuration file.
; It's best edited using the editor UI and not directly,
; since the parameters that go here are not all obvious.
;
; Format:
;   [section] ; section goes between []
;   param=value ; assign values to parameters

config_version=5

[application]

config/name="Climbing Simplified"
config/description="A minimalist physics-based climbing puzzle game where every move matters. Plan your moves, manage stamina, and master different climbing disciplines as you scale gyms, cliffs, and building routes. Each hold behaves differently, and weather conditions can turn an easy climb into a serious challenge."
run/main_scene="uid://cmudrme1ntc3v"
config/features=PackedStringArray("4.5", "Forward Plus")
config/icon="uid://b2ck0fmegil3"

[autoload]

EditorState="*res://scripts/editor/editor_state.gd"
GameState="*res://scripts/levels/game_state.gd"
LevelManager="*res://scripts/levels/level_manager.gd"
Transition="*res://scripts/menus/transition.gd"
LevelTransition="*res://scripts/levels/level_transition.gd"
EnvironmentConfig="*res://scripts/levels/enviornment_config.gd"
HoldRegistry="*res://scripts/holds/hold-registry.gd"

[display]

window/size/viewport_width=1280
window/size/viewport_height=720
window/size/mode=3
window/stretch/mode="canvas_items"

[file_customization]

folder_colors={
"res://assets/": "red",
"res://scenes/": "green",
"res://scripts/": "blue"
}

